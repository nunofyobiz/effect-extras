{
  "name": "@nunofyobiz/effect-extras",
  "version": "0.0.0",
  "description": "Generic, framework-agnostic extensions of the Effect standard library (ArrayX, OptionX, RecordX, StructX, …).",
  "keywords": [
    "effect",
    "effect-ts",
    "functional",
    "typescript",
    "utilities"
  ],
  "homepage": "https://github.com/nunofyobiz/effect-extras#readme",
  "bugs": {
    "url": "https://github.com/nunofyobiz/effect-extras/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nunofyobiz/effect-extras.git"
  },
  "license": "MIT",
  "author": "bigpopakap",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "scripts": {
    "build": "tsup",
    "changeset": "changeset",
    "check-all": "pnpm tc && pnpm lint && pnpm test && pnpm build && pnpm knip",
    "clean": "rm -rf dist *.tsbuildinfo",
    "format": "prettier --write \"**/*.{md,mdx,yml,yaml,json5,css}\"",
    "knip": "knip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "prepublishOnly": "pnpm build",
    "release": "pnpm build && changeset publish",
    "tc": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "testw": "vitest",
    "version-packages": "changeset version"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,tsx,mts,cts}": [
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{md,mdx,yml,yaml,json5,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.5.1",
    "@changesets/cli": "2.29.7",
    "@commitlint/config-conventional": "20.5.3",
    "@commitlint/types": "20.5.0",
    "@effect/language-service": "0.86.2",
    "@effect/vitest": "4.0.0-beta.74",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/compat": "2.0.5",
    "@eslint/js": "10.0.1",
    "@types/node": "24.12.2",
    "@typescript-eslint/parser": "8.60.0",
    "@vitest/coverage-v8": "4.1.7",
    "@vitest/eslint-plugin": "1.6.18",
    "commitlint": "20.5.3",
    "effect": "4.0.0-beta.74",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-package-json": "0.91.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-unicorn": "64.0.0",
    "husky": "9.1.7",
    "knip": "6.4.1",
    "lint-staged": "17.0.7",
    "prettier": "3.8.3",
    "tsup": "8.5.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0",
    "vitest": "4.1.7"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.74"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
