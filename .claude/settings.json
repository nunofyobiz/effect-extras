{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/setup-signing.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(nvm use)",
      "Bash(nvm use *)",
      "Bash(nvm install)",
      "Bash(nvm install *)",
      "Bash(source ~/.nvm/nvm.sh)",
      "Bash(pnpm install)",
      "Bash(pnpm tc)",
      "Bash(pnpm tc *)",
      "Bash(pnpm lint)",
      "Bash(pnpm lint *)",
      "Bash(pnpm lint:fix)",
      "Bash(pnpm test)",
      "Bash(pnpm test *)",
      "Bash(pnpm vitest *)",
      "Bash(pnpm knip)",
      "Bash(pnpm knip *)",
      "Bash(pnpm build)",
      "Bash(pnpm docgen)",
      "Bash(pnpm check-all)",
      "Bash(pnpm check-all *)",
      "Bash(pnpm changeset)",
      "Bash(pnpm changeset *)",
      "Bash(git add)",
      "Bash(git add *)",
      "Bash(git branch --show-current)",
      "Bash(git checkout)",
      "Bash(git checkout *)",
      "Bash(git commit)",
      "Bash(git commit *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git fetch)",
      "Bash(git fetch *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git mv *)",
      "Bash(git push)",
      "Bash(git push -u *)",
      "Bash(git rebase)",
      "Bash(git rebase *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(gh pr create)",
      "Bash(gh pr create *)",
      "Bash(gh pr edit)",
      "Bash(gh pr edit *)",
      "Bash(gh pr view)",
      "Bash(gh pr view *)",
      "Bash(gh api *)",
      "mcp__effect-docs__effect_docs_search",
      "mcp__effect-docs__get_effect_doc"
    ]
  }
}
